{
  "plugin": [
    "opencode-antigravity-auth@1.4.5",
    "opencode-openai-codex-auth"
  ],

  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash":"allow",
    "edit": "ask",
    "write": "deny",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "lsp": "deny",
    "patch": "deny",
    "skill":"allow",
    "todowrite":"allow",
    "todoread":"allow",
    "webfetch": "allow",
    "question": "allow",
  },

  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://aipc.local:11434/v1"
      },
      "models": {
        "primary-coding-model:latest": {
          "name": "Primary Coding Model",
        },
        "fast-coding-model:latest": {
          "name": "Fast Coding Model",
        },
        "code-exploration-model:latest": {
          "name": "Code Exploration Model",
        },
        "reasoning-model:latest": {
          "name": "Reasoning Model",
        },
        "frontend-model:latest": {
          "name": "Frontend UI/UX Engineer Model",
        },
        "multimodal-model:latest": {
          "name": "Multimodal Looker Model",
        }
      }
    }
  },
  "mcp": {
    "kicad": {
      "type": "local",
      "command": [
        "node",
        "../mcps/KiCAD-MCP-Server/dist/index.js"
      ],
      "enabled": true,
      "environment": {
        "LOG_LEVEL": "info"
      }
    }
  },
}