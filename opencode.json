{
  "plugin": [
    "opencode-antigravity-auth@1.6.0",
    "opencode-openai-codex-auth"
  ],

  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash":"allow",
    "edit": "ask",
    "write": "deny",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "lsp": "deny",
    "patch": "deny",
    "skill":"allow",
    "todowrite":"allow",
    "todoread":"allow",
    "webfetch": "allow",
    "question": "allow",
  },

  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://aipc.local:11434/v1"
      },
      "models": {
        "primary-coding-model:latest": {
          "name": "Primary Coding Model",
        },
        "fast-coding-model:latest": {
          "name": "Fast Coding Model",
        },
        "code-exploration-model:latest": {
          "name": "Code Exploration Model",
        },
        "reasoning-model:latest": {
          "name": "Reasoning Model",
        },
        "frontend-model:latest": {
          "name": "Frontend UI/UX Engineer Model",
        },
        "multimodal-model:latest": {
          "name": "Multimodal Looker Model",
        }
      }
    },
    "vllm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "vLLM (local)",
      "options": {
        "baseURL": "http://aipc.local:8000/v1"
      },
      "models": {
        "mistralai/Devstral-Small-2-24B-Instruct-2512": {
          "name": "Devstral S 2 24B",
          "limit": {
            "output": 4096,
            "context": 32768
          }
        },
        "Qwen/Qwen3.5-27B-FP8": {
          "name": "Qwen 3.5 27B FP8",
          "limit": {
            "output": 4096,
            "context": 131072
          }
        }
      }
    }
  },
  "mcp": {
    "kicad": {
      "type": "local",
      "command": [
        "node",
        "../mcps/KiCAD-MCP-Server/dist/index.js"
      ],
      "enabled": true,
      "environment": {
        "LOG_LEVEL": "info"
      }
    }
  },
}